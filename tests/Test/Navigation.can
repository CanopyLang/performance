module Test.Navigation exposing (main, tests)

import Basics exposing (..)
import Expect
import Performance.Navigation as Navigation exposing (NavigationTiming, NavigationMetrics)
import Test exposing (..)


main : Test
main =
    tests


tests : Test
tests =
    describe "Performance.Navigation"
        [ describe "computeMetrics with HTTPS" httpsMetricsTests
        , describe "computeMetrics without HTTPS" httpMetricsTests
        , describe "computeMetrics edge cases" edgeCaseTests
        , describe "positional constructors" positionalConstructorTests
        ]



