-- HTTPS METRICS TESTS


httpsMetricsTests : List Test
httpsMetricsTests =
    let
        metrics =
            Navigation.computeMetrics httpsTiming
    in
    [ test "dnsLookup is domainLookupEnd - domainLookupStart" <|
        \() -> metrics.dnsLookup |> Expect.equal 20
    , test "tcpConnection is connectEnd - connectStart" <|
        \() -> metrics.tcpConnection |> Expect.equal 50
    , test "tlsHandshake is connectEnd - secureConnectionStart when HTTPS" <|
        \() -> metrics.tlsHandshake |> Expect.equal 30
    , test "ttfb is responseStart - fetchStart" <|
        \() -> metrics.ttfb |> Expect.equal 150
    , test "contentDownload is responseEnd - responseStart" <|
        \() -> metrics.contentDownload |> Expect.equal 150
    , test "domParsing is domInteractive - responseEnd" <|
        \() -> metrics.domParsing |> Expect.equal 200
    , test "domContentLoaded is domContentLoadedEventEnd - fetchStart" <|
        \() -> metrics.domContentLoaded |> Expect.equal 550
    , test "pageLoad is loadEventEnd - fetchStart" <|
        \() -> metrics.pageLoad |> Expect.equal 810
    ]



-- HTTP METRICS TESTS


httpMetricsTests : List Test
httpMetricsTests =
    let
        metrics =
            Navigation.computeMetrics httpTiming
    in
    [ test "dnsLookup" <|
        \() -> metrics.dnsLookup |> Expect.equal 10
    , test "tcpConnection" <|
        \() -> metrics.tcpConnection |> Expect.equal 25
    , test "tlsHandshake is 0 when secureConnectionStart is 0" <|
        \() -> metrics.tlsHandshake |> Expect.equal 0
    , test "ttfb" <|
        \() -> metrics.ttfb |> Expect.equal 100
    , test "contentDownload" <|
        \() -> metrics.contentDownload |> Expect.equal 100
    , test "domParsing" <|
        \() -> metrics.domParsing |> Expect.equal 150
    , test "domContentLoaded" <|
        \() -> metrics.domContentLoaded |> Expect.equal 380
    , test "pageLoad" <|
        \() -> metrics.pageLoad |> Expect.equal 510
    ]



-- EDGE CASE TESTS


edgeCaseTests : List Test
edgeCaseTests =
    let
        zeroMetrics =
            Navigation.computeMetrics zeroTiming

        fastMetrics =
            Navigation.computeMetrics fastTiming
    in
    [ test "all-zero timing produces zero dnsLookup" <|
        \() -> zeroMetrics.dnsLookup |> Expect.equal 0
    , test "all-zero timing produces zero tcpConnection" <|
        \() -> zeroMetrics.tcpConnection |> Expect.equal 0
    , test "all-zero timing produces zero tlsHandshake" <|
        \() -> zeroMetrics.tlsHandshake |> Expect.equal 0
    , test "all-zero timing produces zero ttfb" <|
        \() -> zeroMetrics.ttfb |> Expect.equal 0
    , test "all-zero timing produces zero contentDownload" <|
        \() -> zeroMetrics.contentDownload |> Expect.equal 0
    , test "all-zero timing produces zero domParsing" <|
        \() -> zeroMetrics.domParsing |> Expect.equal 0
    , test "all-zero timing produces zero pageLoad" <|
        \() -> zeroMetrics.pageLoad |> Expect.equal 0
    , test "fast page dnsLookup" <|
        \() -> fastMetrics.dnsLookup |> Expect.equal 1
    , test "fast page tcpConnection" <|
        \() -> fastMetrics.tcpConnection |> Expect.equal 4
    , test "fast page tlsHandshake with HTTPS" <|
        \() -> fastMetrics.tlsHandshake |> Expect.equal 3
    , test "fast page ttfb" <|
        \() -> fastMetrics.ttfb |> Expect.equal 10
    , test "fast page contentDownload" <|
        \() -> fastMetrics.contentDownload |> Expect.equal 5
    , test "fast page domParsing" <|
        \() -> fastMetrics.domParsing |> Expect.equal 5
    , test "fast page domContentLoaded" <|
        \() -> fastMetrics.domContentLoaded |> Expect.equal 22
    , test "fast page pageLoad" <|
        \() -> fastMetrics.pageLoad |> Expect.equal 32
    ]


{-| Test positional NavigationTiming and NavigationMetrics constructors
to cover the type alias record constructor coverage points.
NavigationTiming: fetchStart domainLookupStart domainLookupEnd connectStart connectEnd
  secureConnectionStart requestStart responseStart responseEnd domInteractive
  domContentLoadedEventStart domContentLoadedEventEnd domComplete loadEventStart
  loadEventEnd transferSize encodedBodySize decodedBodySize
NavigationMetrics: dnsLookup tcpConnection tlsHandshake ttfb contentDownload
  domParsing domContentLoaded pageLoad
-}
positionalConstructorTests : List Test
positionalConstructorTests =
    [ test "NavigationTiming positional constructor" <|
        \() ->
            let
                timing =
                    NavigationTiming 0 10 30 30 80 50 80 150 300 500 520 550 800 800 810 50000 45000 120000

                metrics =
                    Navigation.computeMetrics timing
            in
            metrics.dnsLookup |> Expect.equal 20
    , test "NavigationMetrics positional constructor" <|
        \() ->
            let
                metrics =
                    NavigationMetrics 20 50 30 150 150 200 550 810
            in
            metrics.dnsLookup |> Expect.equal 20
    , test "NavigationMetrics positional constructor ttfb field" <|
        \() ->
            let
                metrics =
                    NavigationMetrics 10 25 0 100 100 150 380 510
            in
            metrics.ttfb |> Expect.equal 100
    ]
