-- isLcpEntry TESTS


isLcpEntryTests : List Test
isLcpEntryTests =
    [ test "true for LargestContentfulPaintEntry" <|
        \() -> Entry.isLcpEntry (LargestContentfulPaintEntry sampleLcp) |> Expect.equal True
    , test "false for MarkEntry" <|
        \() -> Entry.isLcpEntry (MarkEntry sampleMark) |> Expect.equal False
    , test "false for MeasureEntry" <|
