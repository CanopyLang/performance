isLayoutShiftEntryTests =
    [ test "true for LayoutShiftEntry" <|
        \() -> Entry.isLayoutShiftEntry (LayoutShiftEntry sampleLayoutShift) |> Expect.equal True
    , test "false for MarkEntry" <|
        \() -> Entry.isLayoutShiftEntry (MarkEntry sampleMark) |> Expect.equal False
    , test "false for MeasureEntry" <|
