-- filterMarks TESTS


filterMarksTests : List Test
filterMarksTests =
    [ test "extracts marks from mixed list" <|
        \() -> Entry.filterMarks mixedEntries |> List.length |> Expect.equal 2
    , test "first extracted mark has correct name" <|
        \() ->
            Entry.filterMarks mixedEntries
                |> List.head
                |> Maybe.map .name
                |> Expect.equal (Just "render-start")
    , test "preserves mark detail field" <|
        \() ->
            Entry.filterMarks mixedEntries
                |> List.reverse
                |> List.head
                |> Maybe.andThen .detail
                |> Maybe.map (\_ -> True)
                |> Expect.equal (Just True)
    , test "returns empty list from empty input" <|
        \() -> Entry.filterMarks [] |> Expect.equal []
    , test "returns empty list when no marks present" <|
        \() ->
            Entry.filterMarks [ LongTaskEntry sampleLongTask, EventEntry sampleEvent ]
                |> Expect.equal []
    , test "returns all marks when input is only marks" <|
        \() ->
            Entry.filterMarks [ MarkEntry sampleMark, MarkEntry sampleMarkWithDetail ]
                |> List.length
                |> Expect.equal 2
    ]



-- filterMeasures TESTS


filterMeasuresTests : List Test
filterMeasuresTests =
    [ test "extracts measures from mixed list" <|
        \() -> Entry.filterMeasures mixedEntries |> List.length |> Expect.equal 2
    , test "first extracted measure has correct name" <|
        \() ->
            Entry.filterMeasures mixedEntries
                |> List.head
                |> Maybe.map .name
                |> Expect.equal (Just "render-time")
    , test "preserves measure duration" <|
        \() ->
            Entry.filterMeasures mixedEntries
                |> List.head
                |> Maybe.map .duration
                |> Expect.equal (Just 50.5)
    , test "returns empty list from empty input" <|
        \() -> Entry.filterMeasures [] |> Expect.equal []
    , test "returns empty list when no measures present" <|
        \() ->
            Entry.filterMeasures [ MarkEntry sampleMark, LongTaskEntry sampleLongTask ]
                |> Expect.equal []
    ]



-- filterLongTasks TESTS


filterLongTasksTests : List Test
filterLongTasksTests =
    [ test "extracts long tasks from mixed list" <|
        \() -> Entry.filterLongTasks mixedEntries |> List.length |> Expect.equal 1
    , test "extracted long task has correct name" <|
        \() ->
            Entry.filterLongTasks mixedEntries
                |> List.head
                |> Maybe.map .name
                |> Expect.equal (Just "self")
    , test "extracted long task has correct duration" <|
        \() ->
            Entry.filterLongTasks mixedEntries
                |> List.head
                |> Maybe.map .duration
                |> Expect.equal (Just 120.0)
    , test "returns empty list from empty input" <|
        \() -> Entry.filterLongTasks [] |> Expect.equal []
    , test "returns empty list when no long tasks present" <|
        \() ->
            Entry.filterLongTasks [ MarkEntry sampleMark, MeasureEntry sampleMeasure ]
                |> Expect.equal []
    ]
