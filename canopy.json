{
    "type": "package",
    "name": "canopy/performance",
    "summary": "Performance API bindings: marks, measures, navigation timing, resource timing, Core Web Vitals",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": {
        "Core": [
            "Performance",
            "Performance.Entry"
        ],
        "Observation": [
            "Performance.Observer"
        ],
        "Timing": [
            "Performance.Navigation",
            "Performance.Resource"
        ],
        "Web Vitals": [
            "Performance.Vitals"
        ]
    },
    "canopy-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "canopy/core": "1.0.0 <= v < 2.0.0",
        "canopy/json": "1.1.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "canopy/test": "1.0.0 <= v < 3.0.0",
        "canopy/browser": "1.0.0 <= v < 2.0.0"
    }
}
